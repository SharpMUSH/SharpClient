@using SharpClient.Core.Presentation
@implements IDisposable

<div class="sc-settings">
    <div class="sc-settings-title">Settings</div>

    <div class="sc-settings-section">
        <div class="sc-settings-section-header">Output Font</div>
        <div class="sc-setting">
            <span class="sc-setting-label">Font</span>
            <div class="sc-font-options">
                @foreach (var font in SettingsViewModel.FontOptions)
                {
                    var isActive = Vm.OutputFont == font;
                    <button type="button"
                            class="sc-font-option @(isActive ? "sc-font-option-active" : "")"
                            @onclick="() => Vm.OutputFont = font">
                        @font
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="sc-settings-section">
        <div class="sc-settings-section-header">Layout</div>
        <div class="sc-setting">
            <span class="sc-setting-label">Min columns</span>
            <div class="sc-slider-row">
                <input type="range" class="sc-slider"
                       min="60" max="120" step="1"
                       value="@Vm.MinColumns"
                       @onchange="e => Vm.MinColumns = int.Parse(e.Value!.ToString()!)" />
                <span class="sc-setting-value">@Vm.MinColumns</span>
            </div>
        </div>
        <div class="sc-setting">
            <span class="sc-setting-label">Max text size</span>
            <div class="sc-slider-row">
                <input type="range" class="sc-slider"
                       min="6" max="18" step="1"
                       value="@Vm.MaxFontSize"
                       @onchange="e => Vm.MaxFontSize = int.Parse(e.Value!.ToString()!)" />
                <span class="sc-setting-value">@Vm.MaxFontSize px</span>
            </div>
        </div>
    </div>

    <div class="sc-settings-section">
        <div class="sc-settings-section-header">Accent</div>
        <div class="sc-setting">
            <span class="sc-setting-label">Colour</span>
            <div class="sc-accent-swatches">
                @foreach (var accent in SettingsViewModel.AccentOptions)
                {
                    var isActive = Vm.Accent == accent;
                    <button type="button"
                            class="sc-accent-swatch @(isActive ? "sc-accent-swatch-active" : "")"
                            style="background:@accent"
                            title="@accent"
                            @onclick="() => Vm.Accent = accent">
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="sc-settings-section">
        <div class="sc-settings-section-header">Effects</div>
        <div class="sc-setting">
            <span class="sc-setting-label">Text glow</span>
            <input type="checkbox" class="sc-toggle"
                   checked="@Vm.Glow"
                   @onchange="e => Vm.Glow = (bool)e.Value!" />
        </div>
        <div class="sc-setting">
            <span class="sc-setting-label">Scanlines</span>
            <input type="checkbox" class="sc-toggle"
                   checked="@Vm.Scanlines"
                   @onchange="e => Vm.Scanlines = (bool)e.Value!" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public SettingsViewModel Vm { get; set; } = null!;

    protected override void OnInitialized() => Vm.Changed += OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Vm.Changed -= OnChanged;
}
