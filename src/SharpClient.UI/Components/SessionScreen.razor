@using Microsoft.JSInterop
@using SharpClient.Core.Connection
@using SharpClient.Core.Presentation
@using SharpClient.Core.Sessions

@inject SettingsViewModel Settings
@inject IJSRuntime JS

@implements IAsyncDisposable

<div class="sc-session-screen">
    <div class="sc-session-header">
        <SessionTabs Vm="Vm" />
        <div class="sc-session-actions">
            @* Connection state is already shown as a coloured dot on each tab (SessionTabs), so the
               redundant "Connected" state pill has been removed from the header. *@
            @if (ProtocolVm is not null)
            {
                <button class="sc-protocol-toggle @(_showProtocol ? "sc-protocol-toggle-active" : string.Empty)"
                        @onclick="ToggleProtocol" title="Toggle protocol panel" aria-label="Toggle protocol panel">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M7.5 6 4 10l3.5 4" />
                        <path d="M12.5 6 16 10l-3.5 4" />
                    </svg>
                </button>
            }
        </div>
    </div>
    <div class="sc-output-area" @ref="_outputRef">
        @if (Vm.Active is null)
        {
            <div class="sc-empty-state">
                <p>No active session. Open a session to get started.</p>
            </div>
        }
        else
        {
            <OutputView Lines="Vm.Active.Scrollback" OnSendCommand="cmd => Vm.Active!.SendAsync(cmd)" />
        }
    </div>
    @if (_showProtocol && ProtocolVm is not null)
    {
        <ProtocolPanel Vm="ProtocolVm" />
    }
    <InputBar Vm="Vm" />
</div>

@code {
    [Parameter]
    public SessionsViewModel Vm { get; set; } = null!;

    [Parameter]
    public ProtocolPanelViewModel? ProtocolVm { get; set; }

    private bool _showProtocol;
    private ElementReference _outputRef;
    private IJSObjectReference? _interop;
    private DotNetObjectReference<SessionScreen>? _dotNetRef;
    private int _lastMinColumns;

    protected override void OnInitialized()
    {
        Vm.Changed += OnVmChanged;
        Settings.Changed += OnSettingsChanged;
        _lastMinColumns = Settings.MinColumns;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _interop = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/SharpClient.UI/sc-interop.js");
            await _interop.InvokeVoidAsync("attachAutoScroll", _outputRef);
            var dims = await _interop.InvokeAsync<SizeDims>("observeResize", _dotNetRef, _outputRef);
            await ApplyFontAndNawsAsync(dims.Width, dims.Height);
        }
        else if (_lastMinColumns != Settings.MinColumns)
        {
            _lastMinColumns = Settings.MinColumns;
            // Re-query current size and push updated NAWS.
            if (_interop is not null && _dotNetRef is not null)
            {
                var dims = await _interop.InvokeAsync<SizeDims>("observeResize", _dotNetRef, _outputRef);
                await ApplyFontAndNawsAsync(dims.Width, dims.Height);
            }
        }
    }

    [JSInvokable]
    public async Task OnResized(int width, int height)
    {
        await ApplyFontAndNawsAsync(width, height);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyFontAndNawsAsync(int widthPx, int heightPx)
    {
        if (widthPx <= 0 || _interop is null)
        {
            return;
        }

        // Measure the real character grid and fit the font so MinColumns span the width, then report
        // the resulting grid over NAWS. The measurement (advance + line-height from probes, closed-loop
        // fit for hinting non-linearity, padding-aware) lives in measureGrid, ported from
        // SharpMUSH.Client's terminalMetrics.js so both clients agree — no hard-coded 0.6em advance,
        // which had wrapped an advertised 78 columns ~2 short. measureGrid applies --out-fs (fitted
        // size) and --sc-cols (column track width) on the element.
        var cap = Math.Max(6, Settings.MaxFontSize);
        var grid = await _interop.InvokeAsync<GridDims>("measureGrid", _outputRef, Settings.MinColumns, 6, cap);

        if (Vm.Active is not null)
        {
            await Vm.Active.SendWindowSizeAsync(grid.Cols, grid.Rows);
        }
    }

    private void OnVmChanged() => InvokeAsync(StateHasChanged);

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    private void ToggleProtocol() => _showProtocol = !_showProtocol;

    public async ValueTask DisposeAsync()
    {
        Vm.Changed -= OnVmChanged;
        Settings.Changed -= OnSettingsChanged;

        if (_interop is not null && _dotNetRef is not null)
        {
            await _interop.InvokeVoidAsync("stopObserving", _outputRef);
        }

        _dotNetRef?.Dispose();

        if (_interop is not null)
        {
            await _interop.DisposeAsync();
        }
    }

    private sealed record SizeDims(int Width, int Height);

    private sealed record GridDims(int Cols, int Rows);
}
